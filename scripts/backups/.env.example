# Copie para .env.backup e ajuste apenas no servidor Docker (nunca no repositório).
# -----------------------------------------------------------------------------

# Obrigatório: URL PostgreSQL com permissão INSERT/UPDATE nas tabelas erp_backup_* (ex.: role postgres).
BACKUP_DATABASE_URL=postgresql://postgres:SENHA@127.0.0.1:54322/postgres

# Raiz local onde são criadas subpastas run-YYYY-MM-DD-HH-MM/database|storage|configs
BACKUP_LOCAL_ROOT=/home/naym/sanephub/backups

# --- Base de dados ---
# Se não usar URL completa, pode definir PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE.
# BACKUP_PG_DUMP_EXTRA_ARGS=--schema=public

# --- Storage Supabase (caminho montado no HOST, não dentro do container ERP) ---
SUPABASE_STORAGE_DATA_DIR=/var/lib/docker/volumes/your-stack_storage_volume/_data

# --- Docker / configs ---
DOCKER_PROJECT_DIR=/opt/supabase/stacks/sanephub
BACKUP_CONFIG_PATHS=/etc/nginx/sites-available/sanep.conf:/opt/scripts
# BACKUP_ALLOW_FULL_ENV=false   # apenas true inclui cópia do .env com segredos (risco alto)

# --- Retenção (sobreposto por erp_backup_settings na BD quando BACKUP_DATABASE_URL funciona)
RETENTION_DAYS=30
BACKUP_REMOTE_CLEANUP_ENABLED=false

# --- Google Drive / rclone ---
# RCLONE_REMOTE_ROOT=gdrv:ERP_BACKUPS
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=8
RCLONE_RETRY=3

# Opcional cli psql quando url tem tls strict
# BACKSTACK_PG_OPTS=
