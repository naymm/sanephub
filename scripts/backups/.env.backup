# -----------------------------------------------------------------------------
# BACKUP CONFIG (Supabase Docker - correto para teu setup)
# -----------------------------------------------------------------------------

# PostgreSQL (usar credenciais reais do container supabase_db_sanephub)
PGHOST=127.0.0.1
PGPORT=54322
PGUSER=supabase_admin
PGDATABASE=postgres
PGPASSWORD=postgres

SUPABASE_STORAGE_VOLUME=supabase_storage_sanephub

# URL completa (usada pelo teu script de backup)
BACKUP_DATABASE_URL=postgresql://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}

# -----------------------------------------------------------------------------
# LOCAL BACKUPS
# -----------------------------------------------------------------------------

BACKUP_LOCAL_ROOT=/home/naym/Documentos/NOVO/DEV/sanephub/backups

# -----------------------------------------------------------------------------
# STORAGE SUPABASE (host path)
# -----------------------------------------------------------------------------

SUPABASE_STORAGE_DATA_DIR=/var/lib/docker/volumes/supabase_storage_sanephub/_data

# -----------------------------------------------------------------------------
# PROJECT PATHS
# -----------------------------------------------------------------------------

DOCKER_PROJECT_DIR=/home/naym/Documentos/NOVO/DEV/sanephub
BACKUP_CONFIG_PATHS=/etc/nginx/sites-available:/home/naym/Documentos/NOVO/DEV/sanephub/scripts

# -----------------------------------------------------------------------------
# RETENTION
# -----------------------------------------------------------------------------

RETENTION_DAYS=30
BACKUP_REMOTE_CLEANUP_ENABLED=false

# -----------------------------------------------------------------------------
# RCLONE (se usares Google Drive / cloud)
# -----------------------------------------------------------------------------

RCLONE_TRANSFERS=4
RCLONE_CHECKERS=8
RCLONE_RETRY=3